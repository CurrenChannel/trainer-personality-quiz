---
import MainLayout from "../layouts/MainLayout.astro"
---

<MainLayout title="Trainer Personality Test">
	<h1 class="title">Trainer Personality Test</h1>
	<p>This test determines that kind of trainer you are based on what your favorite Umamusume are. You can select up to 10 favorite Umamusume.</p>
	<div class="toolbar">
		<svg xmlns="http://w3.org" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="search-icon">
			<circle cx="11" cy="11" r="8"></circle>
			<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
		</svg>

		<input type="text" name="search" id="search" placeholder="Search...">
	</div>
</MainLayout>
